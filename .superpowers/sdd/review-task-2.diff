+
+
+def test_human_revision_validates_event_chain_hash_and_serializes_utc_as_z() -> None:
+    timestamp = datetime(2026, 7, 22, 1, 2, 3, tzinfo=UTC)
+    body = {
+        "schema_version": "1.0",
+        "review_id": "review-1",
+        "run_id": "run-1",
+        "record_id": "h01",
+        "status": "confirmed_correct",
+        "source_prediction_hash": "prediction-hash",
